@inherits LayoutComponentBase

<div class="bbf-layout d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg bbf-navbar">
        <div class="container-fluid">
            <a class="navbar-brand bbf-brand" href="/">
                <span class="bbf-logo">🍎</span> BestFarmFriend
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                            <span>📊</span> Dashboard
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/crops">
                            <span>🌱</span> My Crops
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/spray">
                            <span>💧</span> Spray Guide
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/calendar">
                            <span>📅</span> Calendar
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/settings">
                            <span>⚙️</span> Settings
                        </NavLink>
                    </li>
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <LocationPicker />
                </div>
            </div>
        </div>
    </nav>

    <main class="bbf-main flex-grow-1">
        <div class="container-fluid py-3">
            @Body
        </div>
    </main>

    <footer class="bbf-footer text-center py-2 small text-muted">
        BestFarmFriend &copy; @DateTime.Now.Year &mdash; Weather: Open-Meteo &mdash; For informational purposes only.
    </footer>
</div>

<div id="blazor-error-ui" class="alert alert-danger m-3" style="display:none">
    An unhandled error has occurred. <a href="" class="alert-link">Reload</a>
    <button type="button" class="btn-close float-end" onclick="this.parentElement.style.display='none'"></button>
</div>
