@page "/crop/{Slug}"
@rendermode InteractiveServer
@inject ICropRepository CropRepo
@inject IWeatherService WeatherService
@inject ICropAdvisoryService AdvisoryService
@inject ISprayRuleEngine SprayEngine
@inject IAiAdvisoryService AiAdvisory
@inject IGrowthStageService GrowthStageService
@inject BestFarmFriend.Web.Services.AppState AppState
@inject NavigationManager Nav

<PageTitle>@(_crop?.Name ?? "Crop") — BestFarmFriend</PageTitle>

@if (_loading)
{
    <div class="bbf-skeleton mb-3" style="height:60px"></div>
    <div class="row g-3">
        <div class="col-md-6"><div class="bbf-skeleton" style="height:200px"></div></div>
        <div class="col-md-6"><div class="bbf-skeleton" style="height:200px"></div></div>
    </div>
}
else if (_crop == null)
{
    <div class="alert alert-warning">Crop not found.</div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/crops">My Crops</a></li>
            <li class="breadcrumb-item active">@_crop.Name</li>
        </ol>
    </nav>

    <div class="d-flex align-items-center gap-3 mb-4">
        <span class="fs-1">@GetCropEmoji()</span>
        <div>
            <h4 class="mb-0">@_crop.Name</h4>
            <div class="text-muted small">@_crop.Category &bull; @_currentStage.ToString().Replace("_", " ")</div>
        </div>
    </div>

    @if (_weather == null)
    {
        <div class="alert alert-info">Set a location to see advisory data.</div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-6 col-lg-4">
                <WeatherCard Weather="_weather" />
            </div>
            <div class="col-md-6 col-lg-4">
                <SprayReadinessCard SprayResult="_sprayResult" />
            </div>
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header fw-semibold">📋 Action Advisories</div>
                    <div class="card-body">
                        @foreach (var action in _crop.Actions.Where(a => a.IsEnabled))
                        {
                            var adv = _advisories.FirstOrDefault(a => a.ActionType == action.ActionType);
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@GetActionIcon(action.ActionType) @action.DisplayName</span>
                                @if (adv != null)
                                {
                                    <span class="badge @GetStatusBadgeClass(adv.Status)">@adv.Status</span>
                                }
                            </div>
                            @if (adv?.Reasoning is { Length: > 0 })
                            {
                                <p class="small text-muted mb-2 ps-3">@adv.Reasoning</p>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">🤖 AI Advisory</span>
                @if (!_aiLoading)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="LoadAiAdvisory" disabled="@_aiLoading">
                        @(_aiNarrative == null ? "Get AI Advice" : "Refresh")
                    </button>
                }
            </div>
            <div class="card-body">
                @if (_aiLoading)
                {
                    <div class="d-flex align-items-center gap-2 text-muted">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <span>Generating advisory...</span>
                    </div>
                }
                else if (_aiError != null)
                {
                    <div class="alert alert-warning mb-0">@_aiError</div>
                }
                else if (_aiNarrative != null)
                {
                    <p class="mb-0" style="white-space:pre-line">@_aiNarrative</p>
                }
                else
                {
                    <p class="text-muted mb-0">Click "Get AI Advice" for a personalized crop advisory based on current conditions.</p>
                }
            </div>
        </div>

        @if (_crop.GrowthStages.Count > 0)
        {
            <div class="card">
                <div class="card-header fw-semibold">🌿 Growth Stage Calendar</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Stage</th>
                                <th>Typical Timing</th>
                                <th>Key Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var stage in _crop.GrowthStages)
                            {
                                <tr class="@(stage.Stage == _currentStage ? "table-success fw-semibold" : "")">
                                    <td>@stage.DisplayName @(stage.Stage == _currentStage ? "← now" : "")</td>
                                    <td class="small text-muted">Day @stage.TypicalStartDayOfYear – @stage.TypicalEndDayOfYear</td>
                                    <td class="small">@stage.KeyActions</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private Crop? _crop;
    private WeatherSnapshot? _weather;
    private SprayReadinessResult? _sprayResult;
    private List<CropAdvisory> _advisories = new();
    private GrowthStageCode _currentStage;
    private string? _aiNarrative;
    private bool _loading = true;
    private bool _aiLoading;
    private string? _aiError;

    protected override async Task OnInitializedAsync()
    {
        _crop = await CropRepo.GetBySlugAsync(Slug);
        if (_crop != null && AppState.CurrentLocation != null)
        {
            _weather = await WeatherService.GetCurrentWeatherAsync(AppState.CurrentLocation);
            if (_weather != null)
            {
                _sprayResult = SprayEngine.Evaluate(_weather);
                _advisories = await AdvisoryService.GetAdvisoriesAsync(_weather, new[] { _crop });
                _currentStage = GrowthStageService.EstimateCurrentStage(_crop, DateOnly.FromDateTime(DateTime.Today));
            }
        }
        _loading = false;
    }

    private async Task LoadAiAdvisory()
    {
        if (_crop == null || _weather == null || _sprayResult == null) return;
        _aiLoading = true;
        _aiError = null;
        try
        {
            _aiNarrative = await AiAdvisory.GetNarrativeAsync(_weather, _crop, _currentStage, _sprayResult);
        }
        catch (Exception ex)
        {
            _aiError = $"AI advisory unavailable: {ex.Message}";
        }
        finally
        {
            _aiLoading = false;
        }
    }

    private string GetCropEmoji() => Slug switch
    {
        "apple" => "🍎", "pear" => "🍐",
        "cherry-sweet" or "cherry-sour" => "🍒",
        "peach" or "nectarine" => "🍑",
        "grape-wine" or "grape-table" => "🍇",
        "strawberry" => "🍓", "blueberry" => "🫐",
        "tomato" => "🍅",
        "corn-sweet" or "corn-field" => "🌽",
        "wheat" or "alfalfa" => "🌾",
        "walnut" or "almond" or "hazelnut" or "pecan" => "🌰",
        _ => "🌱"
    };

    private static string GetActionIcon(ActionType action) => action switch
    {
        ActionType.Spray => "💧", ActionType.Fertilize => "🧪",
        ActionType.Till => "🚜", ActionType.Groom => "✂️",
        ActionType.Irrigate => "🚿", ActionType.Harvest => "🧺",
        ActionType.Clean => "🧹", _ => "•"
    };

    private static string GetStatusBadgeClass(AdvisoryStatus status) => status switch
    {
        AdvisoryStatus.Recommended => "bg-success",
        AdvisoryStatus.Acceptable => "bg-info text-dark",
        AdvisoryStatus.Caution => "bg-warning text-dark",
        AdvisoryStatus.NotRecommended => "bg-danger",
        _ => "bg-secondary"
    };
}
