@page "/spray"
@rendermode InteractiveServer
@inject IWeatherService WeatherService
@inject ISprayRuleEngine SprayEngine
@inject BestFarmFriend.Web.Services.AppState AppState

<PageTitle>Spray Guide — BestFarmFriend</PageTitle>

<h4 class="mb-3">💧 Spray Readiness Guide</h4>

@if (AppState.CurrentLocation == null)
{
    <div class="alert alert-info">Set your location to see spray readiness.</div>
}
else if (_loading)
{
    <div class="row g-3">
        <div class="col-md-5"><div class="bbf-skeleton" style="height:300px"></div></div>
        <div class="col-md-7"><div class="bbf-skeleton" style="height:300px"></div></div>
    </div>
}
else if (_error != null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_result != null && _weather != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-5">
            <SprayReadinessCard SprayResult="_result" />
        </div>
        <div class="col-md-7">
            <div class="card h-100">
                <div class="card-header fw-semibold">🧪 Product Readiness</div>
                <div class="card-body">
                    @foreach (var p in _result.ProductResults)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2 pb-2 border-bottom">
                            <div>
                                <span class="fw-semibold">@p.ProductType</span>
                                <div class="small text-muted">@p.Reason</div>
                            </div>
                            <span class="badge @GetStatusBadge(p.Status)">@p.Status</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header fw-semibold">📊 Factor Detail</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Factor</th>
                        <th>Current Value</th>
                        <th>Score</th>
                        <th>Status</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in _result.FactorResults)
                    {
                        <tr>
                            <td>@GetFactorIcon(f.Factor) @f.Factor</td>
                            <td class="fw-semibold">@f.CurrentValue</td>
                            <td>
                                <div class="progress" style="width:80px; height:8px">
                                    <div class="progress-bar @GetProgressBarClass(f.Status)"
                                         style="width:@(f.Score)%"></div>
                                </div>
                                <span class="small">@f.Score.ToString("F0")/100</span>
                            </td>
                            <td><span class="badge @GetStatusBadge(f.Status)">@f.Status</span></td>
                            <td class="small text-muted">@f.Reason</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header fw-semibold">📖 Spray Score Algorithm</div>
        <div class="card-body small text-muted">
            <p>The overall spray readiness score (0–100) is a weighted composite:</p>
            <ul>
                <li><strong>Wind</strong> — 30%: gusts &lt;10 mph ideal; &gt;15 mph caution; &gt;20 mph no-go</li>
                <li><strong>Precipitation</strong> — 25%: rain in past 2h or forecast 4h degrades score</li>
                <li><strong>Temperature</strong> — 20%: 50–85°F ideal; extremes reduce efficacy</li>
                <li><strong>Humidity</strong> — 15%: 40–80% RH ideal; dew point gap &lt;10°F = risk</li>
                <li><strong>Time of Day</strong> — 10%: early morning / evening preferred; midday sun penalty</li>
            </ul>
            <table class="table table-sm">
                <thead><tr><th>Score</th><th>Band</th><th>Meaning</th></tr></thead>
                <tbody>
                    <tr class="table-success"><td>80–100</td><td>✅ Go</td><td>Conditions are excellent for spraying</td></tr>
                    <tr class="table-warning"><td>60–79</td><td>⚠️ Caution</td><td>Proceed carefully; monitor conditions</td></tr>
                    <tr><td>40–59</td><td>🟠 Marginal</td><td>Suboptimal; delay if possible</td></tr>
                    <tr class="table-danger"><td>0–39</td><td>🚫 No-Go</td><td>Do not spray; conditions unfavorable</td></tr>
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private WeatherSnapshot? _weather;
    private SprayReadinessResult? _result;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnLocationChanged += async () =>
        {
            _loading = true;
            await LoadAsync();
            StateHasChanged();
        };
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            if (AppState.CurrentLocation != null)
            {
                _weather = await WeatherService.GetCurrentWeatherAsync(AppState.CurrentLocation);
                if (_weather != null)
                    _result = SprayEngine.Evaluate(_weather);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetStatusBadge(FactorStatus status) => status switch
    {
        FactorStatus.Pass => "bg-success",
        FactorStatus.Marginal => "bg-warning text-dark",
        FactorStatus.Fail => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetProgressBarClass(FactorStatus status) => status switch
    {
        FactorStatus.Pass => "bg-success",
        FactorStatus.Marginal => "bg-warning",
        FactorStatus.Fail => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetFactorIcon(SprayFactor f) => f switch
    {
        SprayFactor.Wind => "💨", SprayFactor.Precipitation => "🌧️",
        SprayFactor.Temperature => "🌡️", SprayFactor.Humidity => "💧",
        SprayFactor.TimeOfDay => "🕐", _ => "•"
    };
}
